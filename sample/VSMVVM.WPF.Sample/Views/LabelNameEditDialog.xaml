<Window x:Class="VSMVVM.WPF.Sample.Views.LabelNameEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="Edit label name"
        Width="300"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <StackPanel Margin="{StaticResource P3}">
        <TextBlock Text="Label name"
                   FontSize="{StaticResource TextSm}"
                   FontWeight="{StaticResource FontSemibold}"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="{StaticResource Mb2}"/>
        <TextBox x:Name="NameTextBox"
                 Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="{StaticResource Mb3}">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding CommitLabelNameCommand}"/>
                <KeyBinding Key="Escape" Command="{Binding CancelLabelNameCommand}"/>
            </TextBox.InputBindings>
        </TextBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소"
                    Command="{Binding CancelLabelNameCommand}"
                    IsCancel="True"
                    Padding="{StaticResource Px3}"
                    Margin="{StaticResource Mr2}"/>
            <Button Content="확인"
                    Command="{Binding CommitLabelNameCommand}"
                    IsDefault="True"
                    Padding="{StaticResource Px3}"/>
        </StackPanel>
    </StackPanel>
</Window>
