<UserControl x:Class="VSMVVM.WPF.Sample.Views.LifetimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="DI Lifetime"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="AddSingleton vs AddScoped vs AddTransient comparison."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Singleton -->
                <Border Grid.Column="0" Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="Singleton" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                                   Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="Same instance across all resolves."
                                   FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb3}" TextWrapping="Wrap"/>
                        <TextBlock Text="Instance ID:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding SingletonId}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="Resolve Count:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding SingletonCount}" FontSize="{StaticResource TextLg}" FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb3}"/>
                        <Button Content="Resolve Singleton" Command="{Binding ResolveSingletonCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Scoped -->
                <Border Grid.Column="2" Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="Scoped" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                                   Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="Same instance within a scope, new across scopes."
                                   FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb3}" TextWrapping="Wrap"/>
                        <TextBlock Text="Instance ID:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding ScopedId}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="Resolve Count:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding ScopedCount}" FontSize="{StaticResource TextLg}" FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb3}"/>
                        <Button Content="Resolve Scoped" Command="{Binding ResolveScopedCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Transient -->
                <Border Grid.Column="4" Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="Transient" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                                   Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="New instance on every resolve."
                                   FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb3}" TextWrapping="Wrap"/>
                        <TextBlock Text="Instance ID:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding TransientId}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" Margin="{StaticResource Mb2}"/>
                        <TextBlock Text="Resolve Count:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding TransientCount}" FontSize="{StaticResource TextLg}" FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb3}"/>
                        <Button Content="Resolve Transient" Command="{Binding ResolveTransientCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Log -->
            <TextBlock Text="Resolve Log" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}">
                <TextBlock Text="{Binding ResolveLog}" FontSize="{StaticResource TextSm}"
                           Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
