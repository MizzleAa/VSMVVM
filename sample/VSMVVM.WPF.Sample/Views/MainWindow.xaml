<Window x:Class="VSMVVM.WPF.Sample.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VSMVVM.WPF.Controls;assembly=VSMVVM.WPF"
        xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
        xmlns:media="clr-namespace:VSMVVM.WPF.Media;assembly=VSMVVM.WPF"
        xmlns:ctrl="clr-namespace:VSMVVM.WPF.Design.Core;assembly=VSMVVM.WPF.Design"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        me:ViewModelLocator.AutoWireViewModel="True"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="{Binding Title}" Height="720" Width="1100"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Active menu item style: highlights when ActiveMenu matches Content -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="{StaticResource Mt1}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{x:Static me:EqualityConverter.Instance}">
                            <Binding Path="ActiveMenu"/>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BgPrimary}"/>
                    <Setter Property="FontWeight" Value="{StaticResource FontSemibold}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- AppBar Custom Buttons (최소화 왼쪽에 표시) -->
    <ctrl:WindowChrome.CustomButtons>
        <StackPanel Orientation="Horizontal">
            <!-- Back Button -->
            <Button Command="{Binding NavigateBackCommand}"
                    Style="{StaticResource BtnIcon}"
                    Width="{StaticResource W9}"
                    Height="{StaticResource H9}"
                    ToolTip="Back"
                    Focusable="False"
                    IsEnabled="{Binding CanGoBack}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Path Data="M15 19l-7-7 7-7" Stroke="{DynamicResource TextPrimary}"
                      StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>
            <!-- Forward Button -->
            <Button Command="{Binding NavigateForwardCommand}"
                    Style="{StaticResource BtnIcon}"
                    Width="{StaticResource W9}"
                    Height="{StaticResource H9}"
                    ToolTip="Forward"
                    Focusable="False"
                    IsEnabled="{Binding CanGoForward}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Path Data="M9 5l7 7-7 7" Stroke="{DynamicResource TextPrimary}"
                      StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>
            <!-- Current Page Name -->
            <TextBlock Text="{Binding CurrentViewName}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{StaticResource TextSm}"
                       Margin="8,0,0,0"/>
            <!-- Separator -->
            <Border Width="1" Height="16" Background="{DynamicResource BorderDefault}" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <!-- Info Button -->
            <Button Command="{Binding ToggleInfoCommand}"
                    Style="{StaticResource BtnIcon}"
                    Width="{StaticResource W9}"
                    Height="{StaticResource H9}"
                    ToolTip="App Info"
                    Focusable="False"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Image Source="{media:SvgImage Source=/VSMVVM.WPF.Sample;component/Assets/info_24.svg, Fill={StaticResource AccentPrimary}}"
                       Width="{StaticResource W4}"
                       Height="{StaticResource H4}"/>
            </Button>
        </StackPanel>
    </ctrl:WindowChrome.CustomButtons>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{DynamicResource GridW60}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="{StaticResource BorderR}">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="VSMVVM"
                                   FontSize="{StaticResource TextLg}"
                                   FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource AccentPrimary}"/>
                        <TextBlock Text="WPF Sample v1.0"
                                   FontSize="{StaticResource TextXs}"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="{StaticResource Mt1}"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top"
                        Height="{StaticResource H0_5}"
                        Background="{DynamicResource BorderDefault}"
                        Margin="{StaticResource Mx2}"/>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="{StaticResource M2}">
                        <Button Content="Home" Tag="Home" Command="{Binding NavigateHomeCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Controls" Tag="Controls" Command="{Binding NavigateControlsCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Components" Tag="Components" Command="{Binding NavigateComponentsCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Source Gen" Tag="Source Gen" Command="{Binding NavigateSourceGenCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Messenger" Tag="Messenger" Command="{Binding NavigateMessengerCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Dialog" Tag="Dialog" Command="{Binding NavigateDialogCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Navigation" Tag="Navigation" Command="{Binding NavigateNavigationCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Validation" Tag="Validation" Command="{Binding NavigateValidationCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Services" Tag="Services" Command="{Binding NavigateServicesCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Lifetime" Tag="Lifetime" Command="{Binding NavigateLifetimeCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Default Design" Tag="Default Design" Command="{Binding NavigateDefaultDesignCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Localization" Tag="Localization" Command="{Binding NavigateLocalizationCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Multi Window" Tag="Multi Window" Command="{Binding NavigateMultiWindowCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Logging" Tag="Logging" Command="{Binding NavigateLoggingCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="Canvas" Tag="Canvas" Command="{Binding NavigateCanvasCommand}" Style="{StaticResource NavButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Region -->
        <Border Grid.Column="1" Padding="{StaticResource P4}">
            <controls:WPFRegion RegionName="MainRegion"/>
        </Border>
    </Grid>
</Window>
