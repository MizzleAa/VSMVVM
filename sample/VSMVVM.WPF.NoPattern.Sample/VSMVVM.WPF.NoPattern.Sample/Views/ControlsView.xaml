<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.ControlsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Controls Gallery"
                       FontSize="{StaticResource Text2xl}"
                       FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="{StaticResource Mb4}"/>
            <TextBlock Text="VSMVVM.WPF.Design default styles applied to standard WPF controls."
                       FontSize="{StaticResource TextSm}"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="{StaticResource Mb6}"/>

            <TextBlock Text="Button" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <WrapPanel Margin="{StaticResource Mb6}">
                <Button Content="Default" Margin="{StaticResource Mr2}"/>
                <Button Content="Disabled" IsEnabled="False" Margin="{StaticResource Mr2}"/>
                <Button Content="Long Text Button" Margin="{StaticResource Mr2}"/>
                <ToggleButton Content="Toggle" Margin="{StaticResource Mr2}"/>
                <RepeatButton Content="Repeat" Margin="{StaticResource Mr2}"/>
            </WrapPanel>

            <TextBlock Text="TextBox / PasswordBox" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <StackPanel Margin="{StaticResource Mb6}">
                <TextBox Text="Editable text" Width="{StaticResource W64}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <TextBox Text="Read-only" IsReadOnly="True" Width="{StaticResource W64}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <TextBox Text="Disabled" IsEnabled="False" Width="{StaticResource W64}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <PasswordBox Width="{StaticResource W64}" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Text="CheckBox / RadioButton" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <WrapPanel Margin="{StaticResource Mb6}">
                <CheckBox Content="Option A" IsChecked="True" Margin="{StaticResource Mr4}"/>
                <CheckBox Content="Option B" Margin="{StaticResource Mr4}"/>
                <CheckBox Content="Disabled" IsEnabled="False" Margin="{StaticResource Mr4}"/>
                <RadioButton Content="Radio 1" IsChecked="True" GroupName="G1" Margin="{StaticResource Mr4}"/>
                <RadioButton Content="Radio 2" GroupName="G1" Margin="{StaticResource Mr4}"/>
            </WrapPanel>

            <TextBlock Text="ComboBox" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <ComboBox Width="{StaticResource W64}" HorizontalAlignment="Left" SelectedIndex="0" Margin="{StaticResource Mb6}">
                <ComboBoxItem Content="Item 1"/>
                <ComboBoxItem Content="Item 2"/>
                <ComboBoxItem Content="Item 3"/>
            </ComboBox>

            <TextBlock Text="ListBox" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <ListBox Width="{StaticResource W64}" Height="{StaticResource H24}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <ListBoxItem Content="Apple"/>
                <ListBoxItem Content="Banana"/>
                <ListBoxItem Content="Cherry"/>
                <ListBoxItem Content="Date"/>
                <ListBoxItem Content="Elderberry"/>
            </ListBox>

            <TextBlock Text="ListView" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <ListView x:Name="SampleListView" Width="{StaticResource W96}" Height="{StaticResource H32}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Value" Width="80" DisplayMemberBinding="{Binding Value}"/>
                        <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <TextBlock Text="DataGrid" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <DataGrid x:Name="SampleDataGrid" Width="{StaticResource W96}" Height="{StaticResource H40}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="80"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="TabControl" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <TabControl Width="{StaticResource W96}" Height="{StaticResource H32}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <TabItem Header="Tab 1">
                    <TextBlock Text="Content of Tab 1" Margin="{StaticResource P4}" Foreground="{DynamicResource TextPrimary}"/>
                </TabItem>
                <TabItem Header="Tab 2">
                    <TextBlock Text="Content of Tab 2" Margin="{StaticResource P4}" Foreground="{DynamicResource TextPrimary}"/>
                </TabItem>
                <TabItem Header="Disabled" IsEnabled="False"/>
            </TabControl>

            <TextBlock Text="ProgressBar" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <StackPanel Margin="{StaticResource Mb6}">
                <ProgressBar Value="65" Width="{StaticResource W64}" Height="{StaticResource H2}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <ProgressBar IsIndeterminate="True" Width="{StaticResource W64}" Height="{StaticResource H2}" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Text="Expander" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Expander Header="Click to expand" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <TextBlock Text="Expanded content area. This can hold any content."
                           Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource P3}"/>
            </Expander>

            <TextBlock Text="GroupBox" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <GroupBox Header="Settings Group" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel Margin="{StaticResource P2}">
                    <CheckBox Content="Enable feature A" Margin="{StaticResource Mb2}"/>
                    <CheckBox Content="Enable feature B"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="ToolTip / ContextMenu" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb6}">
                <Button Content="Hover for ToolTip" ToolTip="This is a styled ToolTip!" Margin="{StaticResource Mr2}"/>
                <Button Content="Right-click for ContextMenu">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Cut"/>
                            <MenuItem Header="Copy"/>
                            <MenuItem Header="Paste"/>
                            <Separator/>
                            <MenuItem Header="Delete"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
