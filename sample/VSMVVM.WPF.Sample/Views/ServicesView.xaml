<UserControl x:Class="VSMVVM.WPF.Sample.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Services"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="Guard, DispatcherService, and StateStore demos."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <!-- Guard -->
            <TextBlock Text="Guard" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <TextBlock Text="Guard Input:" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBox Text="{Binding GuardInput, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Mb3}"/>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb2}">
                        <Button Content="IsNotNull" Command="{Binding TestNotNullCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="IsNotNullOrEmpty" Command="{Binding TestNotNullOrEmptyCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="IsInRange(1-100)" Command="{Binding TestInRangeCommand}"/>
                    </StackPanel>
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedSm}" Padding="{StaticResource P2}">
                        <TextBlock Text="{Binding GuardResult}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Dispatcher -->
            <TextBlock Text="DispatcherService" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <Button Content="Update from Background Thread" Command="{Binding DispatcherTestCommand}" Margin="{StaticResource Mb2}"/>
                    <TextBlock Text="{Binding DispatcherStatus}" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- StateStore -->
            <TextBlock Text="StateStore (Redux-style)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <TextBlock Text="StateStoreBase&lt;AppState&gt;: Subscribe for reactive state, UpdateState for immutable updates."
                       FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb2}"/>
            <Button Content="🪟 Open SubWindow (compare state)" Command="{Binding OpenSubWindowCommand}"
                    HorizontalAlignment="Left" Margin="{StaticResource Mb3}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb3}">
                        <TextBlock Text="Counter:" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="{StaticResource Mr2}"/>
                        <TextBlock Text="{Binding StoreCounter}" FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource AccentPrimary}" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb3}">
                        <Button Content="Increment" Command="{Binding StoreIncrementCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="Decrement" Command="{Binding StoreDecrementCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="Reset" Command="{Binding StoreResetCommand}"/>
                    </StackPanel>
                    <TextBlock Text="Last Action:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb1}"/>
                    <TextBlock Text="{Binding StoreLastAction}" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb2}"/>
                    <TextBlock Text="Subscribe Log:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb1}"/>
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedSm}" Padding="{StaticResource P2}" MaxHeight="120">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding StoreLog}" FontSize="{StaticResource TextXs}"
                                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" FontFamily="Consolas"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
