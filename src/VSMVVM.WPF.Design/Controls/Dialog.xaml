<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:ctrl="clr-namespace:VSMVVM.WPF.Design.Core">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Sizing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Effects.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Typography.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ==================== -->
    <!-- Dialog Button Styles -->
    <!-- ==================== -->

    <!-- Primary Button (OK, Yes) - Accent colored -->
    <Style x:Key="DialogButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextInverse}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="MinWidth" Value="{StaticResource W20}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RoundedMd}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryActive}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary Button (Cancel, No) - Subtle, outlined -->
    <Style x:Key="DialogButtonSecondary" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="MinWidth" Value="{StaticResource W20}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RoundedMd}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgMuted}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== -->
    <!-- Dialog Window Style  -->
    <!-- ==================== -->

    <!-- Dialog-specific Window Style: simplified titlebar (close only), no resize -->
    <Style x:Key="VSMVVMDialogWindowStyle" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource BgPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource TextBase}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="False"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="ctrl:WindowButtonsBehavior.Enable" Value="True"/>
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="{StaticResource H9}"
                                    ResizeBorderThickness="0"
                                    GlassFrameThickness="0"
                                    CornerRadius="{StaticResource RoundedNone}"
                                    UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border x:Name="PART_ContentBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="{StaticResource Border}"
                            Effect="{StaticResource ShadowXl}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{StaticResource GridH9}"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Title Bar (simplified: title + close only) -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource BgSecondary}"
                                    BorderBrush="{DynamicResource BorderMuted}"
                                    BorderThickness="{StaticResource BorderB}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon + Title -->
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                Margin="{StaticResource Mx2}"
                                                VerticalAlignment="Center">
                                        <Image Source="{TemplateBinding Icon}"
                                               Width="{StaticResource W4}"
                                               Height="{StaticResource H4}"
                                               Margin="{StaticResource Mr2}"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="{StaticResource TextSm}"
                                                   FontWeight="{StaticResource FontMedium}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Close Only -->
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button x:Name="closeButton"
                                                Command="{x:Static SystemCommands.CloseWindowCommand}"
                                                Width="{StaticResource W11}"
                                                Height="{StaticResource H9}"
                                                Foreground="{DynamicResource TextSecondary}"
                                                Focusable="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="Transparent"
                                                            Padding="{StaticResource P1}"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Error}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ErrorHover}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Path Data="M0,0 L10,10 M10,0 L0,10"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="{StaticResource H0_5}"
                                                  Stretch="Uniform"
                                                  Width="{StaticResource W2_5}"
                                                  Height="{StaticResource H2_5}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Content Area -->
                            <AdornerDecorator Grid.Row="1">
                                <ContentPresenter/>
                            </AdornerDecorator>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
