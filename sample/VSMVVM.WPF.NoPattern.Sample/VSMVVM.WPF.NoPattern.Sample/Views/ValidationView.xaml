<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.ValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Validation"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="Manual validation in code-behind — no INotifyDataErrorInfo, just TextChanged + direct error TextBlock updates."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Name (required, 2-50 chars):" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBox x:Name="NameBox" TextChanged="Field_Changed" Margin="{StaticResource Mb1}"/>
                    <TextBlock x:Name="NameError" FontSize="{StaticResource TextXs}"
                               Foreground="{DynamicResource Danger}" Margin="{StaticResource Mb3}"/>

                    <TextBlock Text="Email (required, email format):" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBox x:Name="EmailBox" TextChanged="Field_Changed" Margin="{StaticResource Mb1}"/>
                    <TextBlock x:Name="EmailError" FontSize="{StaticResource TextXs}"
                               Foreground="{DynamicResource Danger}" Margin="{StaticResource Mb3}"/>

                    <TextBlock Text="Age (1-150):" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBox x:Name="AgeBox" TextChanged="Field_Changed" Margin="{StaticResource Mb1}"/>
                    <TextBlock x:Name="AgeError" FontSize="{StaticResource TextXs}"
                               Foreground="{DynamicResource Danger}" Margin="{StaticResource Mb3}"/>

                    <Button Content="Submit" Click="Submit_Click" Margin="{StaticResource Mt2}"/>
                    <TextBlock x:Name="SubmitResult" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mt2}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
