<Window x:Class="VSMVVM.WPF.Sample.Views.ChartViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
        xmlns:charts="clr-namespace:VSMVVM.WPF.Design.Components.Charts;assembly=VSMVVM.WPF.Design"
        xmlns:vm="clr-namespace:VSMVVM.WPF.Sample.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:ChartViewWindowViewModel}"
        mc:Ignorable="d"
        me:ViewModelLocator.AutoWireViewModel="True"
        Style="{DynamicResource VSMVVMWindowStyle}"
        Title="Chart View" Width="720" Height="560"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- 헤더 -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgTertiary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{DynamicResource Px3Py2}">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14"
                           Foreground="{DynamicResource TextPrimary}">
                    <Run Text="ChartView:"/>
                    <Run Text="{Binding ViewName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11"
                           Margin="{DynamicResource Mt0_5}"/>
            </StackPanel>
        </Border>

        <!-- 하단 Close -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,1,0,0"
                Padding="{DynamicResource Px3Py2}">
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    MinWidth="80"
                    Click="OnCloseClick"/>
        </Border>

        <!-- 본문: Kind 에 따라 LineChart 또는 ConfusionMatrix 표시 -->
        <Grid>
            <charts:LineChart Series="{Binding LineSeries}"
                              Visibility="{Binding IsLine, Converter={StaticResource BoolToVisibility}}"
                              Margin="8"/>

            <charts:ConfusionMatrix Matrix="{Binding Matrix}"
                                    RowLabels="{Binding RowLabels}"
                                    ColumnLabels="{Binding ColumnLabels}"
                                    RowAxisTitle="{Binding RowAxisTitle}"
                                    ColumnAxisTitle="{Binding ColumnAxisTitle}"
                                    ShowCellValues="True"
                                    Visibility="{Binding IsMatrix, Converter={StaticResource BoolToVisibility}}"
                                    Margin="8"/>

            <charts:Heatmap Data="{Binding Matrix}"
                            Visibility="{Binding IsHeatmap, Converter={StaticResource BoolToVisibility}}"
                            Margin="8"/>
        </Grid>
    </DockPanel>
</Window>
