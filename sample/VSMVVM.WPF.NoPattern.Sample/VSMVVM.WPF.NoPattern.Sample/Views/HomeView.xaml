<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="Hello, World!"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="{StaticResource Text3xl}"
                       FontWeight="{StaticResource FontBold}"/>

            <TextBlock Text="VSMVVM.WPF.Design — no MVVM, just code-behind"
                       HorizontalAlignment="Center"
                       Margin="{StaticResource Mt2}"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{StaticResource TextSm}"/>

            <TextBlock x:Name="CountText"
                       Text="0"
                       HorizontalAlignment="Center"
                       Margin="{StaticResource Mt6}"
                       Foreground="{DynamicResource AccentPrimary}"
                       FontSize="{StaticResource Text4xl}"
                       FontWeight="{StaticResource FontBold}"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="{StaticResource Mt4}">
                <Button x:Name="CounterButton"
                        Content="Click me"
                        Click="CounterButton_Click"/>
                <Button x:Name="ResetButton"
                        Content="Reset"
                        Margin="{StaticResource Ml2}"
                        Background="{DynamicResource AccentSecondary}"
                        Click="ResetButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
