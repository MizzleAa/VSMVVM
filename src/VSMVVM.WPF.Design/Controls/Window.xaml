<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:ctrl="clr-namespace:VSMVVM.WPF.Design.Core">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Sizing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Effects.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Typography.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Title Bar Button Template (Minimize, Maximize, Close) -->
    <ControlTemplate x:Key="TitleBarButtonTemplate" TargetType="Button">
        <Border x:Name="border"
                Background="Transparent"
                Padding="{StaticResource P1}"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgTertiary}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgMuted}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Close Button Template (Red hover) -->
    <ControlTemplate x:Key="TitleBarCloseButtonTemplate" TargetType="Button">
        <Border x:Name="border"
                Background="Transparent"
                Padding="{StaticResource P1}"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource Error}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource ErrorHover}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Default Window Style -->
    <Style x:Key="VSMVVMWindowStyle" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource BgPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
        <Setter Property="FontSize" Value="{StaticResource TextBase}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="ctrl:WindowButtonsBehavior.Enable" Value="True"/>
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="{StaticResource H9}"
                                    ResizeBorderThickness="6"
                                    GlassFrameThickness="0"
                                    CornerRadius="{StaticResource RoundedNone}"
                                    UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border x:Name="PART_ContentBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="{StaticResource Border}"
                            CornerRadius="{StaticResource RoundedLg}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- 둥근 모서리 클리핑 마스크 (VisualBrush 소스) -->
                            <Border x:Name="PART_ClipMask"
                                    CornerRadius="{StaticResource RoundedLg}"
                                    Background="{DynamicResource BgPrimary}"/>

                            <!-- 실제 콘텐츠 (OpacityMask로 둥근 모서리 클리핑) -->
                            <Grid x:Name="PART_ContentGrid">
                                <Grid.OpacityMask>
                                    <VisualBrush Visual="{x:Reference PART_ClipMask}"/>
                                </Grid.OpacityMask>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="{StaticResource GridH9}"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- Title Bar -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource BgSecondary}"
                                        BorderBrush="{DynamicResource BorderMuted}"
                                        BorderThickness="{StaticResource BorderB}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon + Title -->
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Margin="{StaticResource Mx2}"
                                                    VerticalAlignment="Center">
                                            <Image Source="{TemplateBinding Icon}"
                                                   Width="{StaticResource W4}"
                                                   Height="{StaticResource H4}"
                                                   Margin="{StaticResource Mr2}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{TemplateBinding Title}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="{StaticResource TextSm}"
                                                       FontWeight="{StaticResource FontMedium}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Custom Buttons Area (최소화 왼쪽) -->
                                        <ContentPresenter Grid.Column="2"
                                                          Content="{Binding Path=(ctrl:WindowChrome.CustomButtons), RelativeSource={RelativeSource TemplatedParent}}"
                                                          VerticalAlignment="Center"
                                                          Margin="{StaticResource Mr1}"
                                                          shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                                        <!-- System Buttons -->
                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                            <!-- Minimize -->
                                            <Button x:Name="minimizeButton"
                                                    Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                                    Width="{StaticResource W11}"
                                                    Height="{StaticResource H9}"
                                                    Template="{StaticResource TitleBarButtonTemplate}"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Focusable="False">
                                                <Path Data="M4,0 L16,0"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="{StaticResource H0_5}"
                                                      Stretch="None"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Button>

                                            <!-- Maximize/Restore -->
                                            <Button x:Name="maximizeButton"
                                                    Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                                    Width="{StaticResource W11}"
                                                    Height="{StaticResource H9}"
                                                    Template="{StaticResource TitleBarButtonTemplate}"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Focusable="False">
                                                <Path x:Name="maximizeIcon"
                                                      Data="M1,1 L1,11 L11,11 L11,1 Z"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="{StaticResource H0_5}"
                                                      Stretch="Uniform"
                                                      Width="{StaticResource W2_5}"
                                                      Height="{StaticResource H2_5}"/>
                                            </Button>

                                            <!-- Close -->
                                            <Button x:Name="closeButton"
                                                    Command="{x:Static SystemCommands.CloseWindowCommand}"
                                                    Width="{StaticResource W11}"
                                                    Height="{StaticResource H9}"
                                                    Template="{StaticResource TitleBarCloseButtonTemplate}"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Focusable="False">
                                                <Path Data="M0,0 L10,10 M10,0 L0,10"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="{StaticResource H0_5}"
                                                      Stretch="Uniform"
                                                      Width="{StaticResource W2_5}"
                                                      Height="{StaticResource H2_5}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Content Area -->
                                <AdornerDecorator Grid.Row="1">
                                    <ContentPresenter/>
                                </AdornerDecorator>
                            </Grid>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- 최대화 시: 둥근 모서리 제거, 테두리 제거, 패딩으로 잘림 방지 -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_ContentBorder" Property="CornerRadius" Value="{StaticResource RoundedNone}"/>
                            <Setter TargetName="PART_ContentBorder" Property="BorderThickness" Value="{StaticResource Border0}"/>
                            <Setter TargetName="PART_ContentBorder" Property="Padding" Value="{StaticResource P2}"/>
                            <Setter TargetName="PART_ClipMask" Property="CornerRadius" Value="{StaticResource RoundedNone}"/>
                            <Setter TargetName="PART_ContentGrid" Property="OpacityMask" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

