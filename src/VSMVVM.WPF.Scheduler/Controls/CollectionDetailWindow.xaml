<Window x:Class="VSMVVM.WPF.Scheduler.Controls.CollectionDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VSMVVM.WPF.Scheduler.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:CollectionDetailViewModel}"
        mc:Ignorable="d"
        Style="{DynamicResource VSMVVMWindowStyle}"
        Title="Collection Detail"
        Width="620" Height="560"
        MinWidth="380" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}"
        ShowInTaskbar="False">

    <DockPanel LastChildFill="True">

        <!-- 헤더 — 루트 표시명 + 현재 타입/개수 + 브레드크럼 -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{DynamicResource Px3Py2}">
            <StackPanel>
                <TextBlock Text="{Binding RootDisplayName}"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Foreground="{DynamicResource TextMuted}"
                           FontSize="11"
                           Margin="{DynamicResource Mt0_5}">
                    <Run Text="Type:"/>
                    <Run Text="{Binding HeaderType, Mode=OneWay}"/>
                    <Run Text=" | Count:"/>
                    <Run Text="{Binding HeaderCount, Mode=OneWay}"/>
                </TextBlock>

                <!-- 브레드크럼 -->
                <ItemsControl ItemsSource="{Binding Path}"
                              Margin="{DynamicResource Mt1}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CollectionPathSegment}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="{Binding Label}"
                                        Padding="6,1"
                                        MinHeight="0"
                                        FontSize="11"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource AccentPrimary}"
                                        Command="{Binding DataContext.NavigateToCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <TextBlock Text=" › "
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 하단 — Close -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,1,0,0"
                Padding="{DynamicResource Px3Py2}">
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    MinWidth="80"
                    Click="OnCloseClick"/>
        </Border>

        <!-- 본문 — ListView + GridView (가상화). 컬렉션 행은 더블클릭으로 드릴다운. -->
        <ListView x:Name="RowsList"
                  ItemsSource="{Binding Rows}"
                  Background="{DynamicResource BgPrimary}"
                  BorderThickness="0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  MouseDoubleClick="OnRowDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Key"
                                    Width="120"
                                    DisplayMemberBinding="{Binding Key}"/>
                    <GridViewColumn Header="Value" Width="380">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:CollectionRow}">
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text=" ▶"
                                               Foreground="{DynamicResource AccentPrimary}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               ToolTip="더블클릭하여 안쪽 보기">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Value}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</Window>
