<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<LangVersion>12</LangVersion>
		<Nullable>disable</Nullable>
		<Platforms>AnyCPU;x64;x86</Platforms>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<EnforceExtendedAnalyzerRules>True</EnforceExtendedAnalyzerRules>
		<IncludePackageReferencesDuringMarkupCompilation>True</IncludePackageReferencesDuringMarkupCompilation>
		<CopyLocalLockFileAssemblies>True</CopyLocalLockFileAssemblies>
		<RootNamespace>VSMVVM.Core</RootNamespace>
		<AssemblyName>VSMVVM.Core</AssemblyName>
		<PackageId>VSMVVM.Core</PackageId>
		<Version>1.0.3</Version>
		<Title>VSMVVM.Core</Title>
		<Description>Lightweight MVVM core framework with built-in Source Generator, DI container, Messenger, and Guard utilities. Targets .NET Standard 2.0.</Description>
		<PackageTags>mvvm;ioc;di;source-generator;messenger;vsmvvm</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
		<PackageReference Include="System.ComponentModel.Annotations" Version="5.0.0" />
		<None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
	</ItemGroup>

</Project>
