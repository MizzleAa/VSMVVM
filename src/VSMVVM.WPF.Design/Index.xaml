        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/DataGrid.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/TabControl.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/ScrollViewer.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/ProgressBar.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/ContextMenu.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Expander.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Window.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Dialog.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Panels.xaml"/>

        <!-- Components -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Components/LoadingOverlay.xaml"/>
