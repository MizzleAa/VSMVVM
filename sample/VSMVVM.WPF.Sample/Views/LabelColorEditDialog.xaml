<Window x:Class="VSMVVM.WPF.Sample.Views.LabelColorEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:VSMVVM.WPF.Controls;assembly=VSMVVM.WPF"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="Edit label color"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <StackPanel Margin="{StaticResource P3}">
        <ctrl:ColorPicker SelectedColor="{Binding EditingColor, Mode=TwoWay}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource Mt3}">
            <Button Content="취소"
                    Command="{Binding CancelLabelColorCommand}"
                    IsCancel="True"
                    Padding="{StaticResource Px3}"
                    Margin="{StaticResource Mr2}"/>
            <Button Content="확인"
                    Command="{Binding CommitLabelColorCommand}"
                    IsDefault="True"
                    Padding="{StaticResource Px3}"/>
        </StackPanel>
    </StackPanel>
</Window>
