<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Colors/Palette.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Effects.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ======================================== -->
    <!-- SECTION PANEL                           -->
    <!-- ======================================== -->

    <!-- SectionPanel: Rounded container with subtle shadow for depth -->
    <Style x:Key="SectionPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource Border}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RoundedLg}"/>
        <Setter Property="Padding" Value="{StaticResource P4}"/>
        <Setter Property="Effect" Value="{StaticResource ShadowMd}"/>
    </Style>

    <!-- ======================================== -->
    <!-- GLASS PANEL (Glassmorphism)              -->
    <!-- ======================================== -->

    <!-- GlassPanel Brushes -->
    <SolidColorBrush x:Key="GlassPanelBg" Color="{StaticResource Zinc900}" Opacity="{StaticResource Opacity60}"/>
    <SolidColorBrush x:Key="GlassPanelBorder" Color="{StaticResource Zinc700}" Opacity="{StaticResource Opacity60}"/>

    <!-- GlassPanel: Semi-transparent card for gradient backgrounds -->
    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassPanelBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassPanelBorder}"/>
        <Setter Property="BorderThickness" Value="{StaticResource Border}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RoundedLg}"/>
        <Setter Property="Padding" Value="{StaticResource P4}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- GlassPanelDisableable: GlassPanel + IsEnabled=False 시 Opacity 0.4 적용 -->
    <Style x:Key="GlassPanelDisableable" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity40}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ======================================== -->
    <!-- GLASS BACKGROUND (Mesh Gradient)         -->
    <!-- ======================================== -->

    <!-- GlassBackground: Organic mesh gradient using layered radial gradients -->
    <DrawingBrush x:Key="GlassMeshGradient" Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base: solid dark fill -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,1,1"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="{StaticResource Zinc950}"/>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Radial 1: subtle navy glow, top-right -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,1,1"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center="0.8,0.15" RadiusX="0.35" RadiusY="0.3"
                                              GradientOrigin="0.8,0.15" Opacity="0.6">
                            <GradientStop Color="{StaticResource Slate950}" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Radial 2: subtle blue hint, bottom-center -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,1,1"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center="0.4,0.85" RadiusX="0.4" RadiusY="0.3"
                                              GradientOrigin="0.4,0.85" Opacity="0.6">
                            <GradientStop Color="{StaticResource Zinc800}" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Radial 3: faint glow, center-left -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,1,1"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center="0.2,0.5" RadiusX="0.25" RadiusY="0.35"
                                              GradientOrigin="0.2,0.5" Opacity="0.6">
                            <GradientStop Color="{StaticResource Zinc800}" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style x:Key="GlassBackground" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource GlassMeshGradient}"/>
    </Style>

</ResourceDictionary>
