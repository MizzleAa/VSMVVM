<UserControl x:Class="VSMVVM.WPF.Sample.Views.DialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Dialog Service"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="IDialogService demo with Design system styled modal dialogs."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <!-- Section Title -->
                    <TextBlock Text="Dialog Buttons Preset" FontSize="{StaticResource TextBase}"
                               FontWeight="{StaticResource FontSemibold}" Foreground="{DynamicResource AccentPrimary}"
                               Margin="{StaticResource Mb3}"/>

                    <Button Content="Show Message (OK)" Command="{Binding ShowMessageCommand}" Margin="{StaticResource Mb2}"/>
                    <Button Content="Show Confirm (Yes/No)" Command="{Binding ShowConfirmCommand}" Margin="{StaticResource Mb2}"/>
                    <Button Content="Show OK/Cancel" Command="{Binding ShowOKCancelCommand}" Margin="{StaticResource Mb2}"/>

                    <!-- Result Display -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedMd}"
                            Padding="{StaticResource Px3Py2}" Margin="{StaticResource Mt3}">
                        <TextBlock Text="{Binding DialogResult}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Info Section -->
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left"
                    Margin="{StaticResource Mt4}">
                <StackPanel>
                    <TextBlock Text="Design System Integration" FontSize="{StaticResource TextBase}"
                               FontWeight="{StaticResource FontSemibold}" Foreground="{DynamicResource AccentPrimary}"
                               Margin="{StaticResource Mb2}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}"
                               LineHeight="18">
                        <Run Text="• VSMVVMDialogWindowStyle — Simplified titlebar (close only)"/>
                        <LineBreak/>
                        <Run Text="• DialogButtonPrimary — Accent colored action button"/>
                        <LineBreak/>
                        <Run Text="• DialogButtonSecondary — Subtle secondary button"/>
                        <LineBreak/>
                        <Run Text="• Auto-applied via DialogService.ShowDialog()"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
