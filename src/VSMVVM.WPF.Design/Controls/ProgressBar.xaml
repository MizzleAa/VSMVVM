<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Sizing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Effects.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Default ProgressBar -->
    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="BorderThickness" Value="{StaticResource Border0}"/>
        <Setter Property="Height" Value="{StaticResource H1_5}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource RoundedSm}" SnapsToDevicePixels="True">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource RoundedSm}"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default Slider Thumb -->
    <ControlTemplate x:Key="SliderThumbTemplate" TargetType="Thumb">
        <Ellipse x:Name="thumb"
                 Width="{StaticResource W4}"
                 Height="{StaticResource H4}"
                 Fill="{DynamicResource AccentPrimary}"
                 Stroke="{DynamicResource BgPrimary}"
                 StrokeThickness="{DynamicResource H0_5}"/>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="thumb" Property="Fill" Value="{DynamicResource AccentPrimaryHover}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Default Slider -->
    <Style TargetType="{x:Type Slider}">
        <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="Height" Value="{StaticResource H6}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="{StaticResource H1}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RoundedSm}"
                                SnapsToDevicePixels="True"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Template="{StaticResource SliderThumbTemplate}" Cursor="Hand"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
