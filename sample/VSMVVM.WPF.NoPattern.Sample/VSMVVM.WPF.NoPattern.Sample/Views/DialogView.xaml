<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.DialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Dialog (MessageBox)"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="Standard WPF MessageBox.Show() — no DialogService, no MVVM."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="MessageBox Presets" FontSize="{StaticResource TextBase}"
                               FontWeight="{StaticResource FontSemibold}" Foreground="{DynamicResource AccentPrimary}"
                               Margin="{StaticResource Mb3}"/>

                    <Button Content="Show Message (OK)" Click="ShowMessage_Click" Margin="{StaticResource Mb2}"/>
                    <Button Content="Show Confirm (Yes/No)" Click="ShowConfirm_Click" Margin="{StaticResource Mb2}"/>
                    <Button Content="Show OK/Cancel" Click="ShowOKCancel_Click" Margin="{StaticResource Mb2}"/>

                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedMd}"
                            Padding="{StaticResource Px3Py2}" Margin="{StaticResource Mt3}">
                        <TextBlock x:Name="DialogResultText"
                                   Text="No dialog shown yet."
                                   FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left"
                    Margin="{StaticResource Mt4}">
                <StackPanel>
                    <TextBlock Text="Note" FontSize="{StaticResource TextBase}"
                               FontWeight="{StaticResource FontSemibold}" Foreground="{DynamicResource AccentPrimary}"
                               Margin="{StaticResource Mb2}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}"
                               LineHeight="18">
                        <Run Text="Standard MessageBox uses the OS-native dialog and does not pick up the VSMVVM.WPF.Design theme."/>
                        <LineBreak/>
                        <Run Text="If you need a fully-themed modal, use IDialogService from the VSMVVM.WPF package (see the full Sample)."/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
