        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Utilities.xaml"/>

        <!-- Color Palette (Static) -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Colors/Palette.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Colors/PaletteBrushes.xaml"/>

        <!-- Theme (Dark by default) -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Colors/ThemeDark.xaml"/>

        <!-- Default Control Styles -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Text.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/Button.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/TextBox.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Controls/CheckBox.xaml"/>
