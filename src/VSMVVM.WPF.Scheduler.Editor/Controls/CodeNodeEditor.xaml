<UserControl x:Class="VSMVVM.WPF.Scheduler.Editor.Controls.CodeNodeEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <avalon:TextEditor x:Name="Editor"
                       Background="{DynamicResource BgPrimary}"
                       Foreground="{DynamicResource TextPrimary}"
                       FontFamily="Cascadia Mono, Consolas"
                       FontSize="13"
                       ShowLineNumbers="True"
                       LineNumbersForeground="{DynamicResource TextMuted}"
                       BorderBrush="{DynamicResource BorderDefault}"
                       BorderThickness="1"
                       Padding="{DynamicResource P3}"
                       WordWrap="False"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto"/>
</UserControl>
