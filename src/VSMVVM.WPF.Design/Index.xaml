<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VSMVVM.WPF.Design Resource System -->
    <!-- App.xaml에서 이 하나의 파일만 Merge하면 전체 디자인이 적용됩니다 -->

    <ResourceDictionary.MergedDictionaries>

        <!-- Design Tokens -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
