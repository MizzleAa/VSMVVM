<UserControl x:Class="VSMVVM.WPF.Sample.Views.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Navigation"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="IRegionManager + INavigateAware lifecycle demo."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Navigation Log" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                               Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb3}"/>
                    <TextBlock Text="Use sidebar to navigate between pages. This page logs navigation lifecycle events."
                               FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb3}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding NavigationLog}" FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
