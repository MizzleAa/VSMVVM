<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">

    <ResourceDictionary.MergedDictionaries>
        <!-- VSMVVM.WPF.Design 머지: Spacing/Sizing/Typography/Effects 토큰 + Palette + ThemeDark + 컴포넌트 스타일 -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Index.xaml"/>
        <!-- AvalonEdit CompletionWindow / CompletionList 스타일 (Phase 8c) -->
        <ResourceDictionary Source="/VSMVVM.WPF.Scheduler.Editor;component/Themes/CompletionWindow.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- TextEditor 디폴트 스타일 — CodeNodeEditor.xaml 인라인 설정과 일관성 유지하되, 직접 사용 시에도 적용됨. -->
    <Style TargetType="{x:Type avalon:TextEditor}">
        <Setter Property="Background"        Value="{DynamicResource BgPrimary}"/>
        <Setter Property="Foreground"        Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily"        Value="Cascadia Mono, Consolas"/>
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="BorderBrush"       Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="{DynamicResource P3}"/>
        <Setter Property="ShowLineNumbers"   Value="True"/>
        <Setter Property="LineNumbersForeground" Value="{DynamicResource TextMuted}"/>
    </Style>

    <Style TargetType="{x:Type avalon:TextArea}">
        <Setter Property="SelectionBrush"      Value="{DynamicResource AccentPrimaryMuted}"/>
        <Setter Property="SelectionBorder"     Value="{DynamicResource BorderFocus}"/>
        <Setter Property="SelectionForeground" Value="{x:Null}"/>
    </Style>

</ResourceDictionary>
