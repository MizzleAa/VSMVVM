<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.MultiWindowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Multi Window"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="Cross-window state sync via App static property + plain C# event — no IMessenger, no DI."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <TextBlock Text="Shared Counter (Main)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <TextBlock x:Name="CountText"
                               Text="0"
                               FontSize="{StaticResource Text2xl}"
                               FontWeight="{StaticResource FontBold}"
                               Foreground="{DynamicResource AccentPrimary}"
                               FontFamily="Consolas"/>
                    <Button Content="Increment from Main"
                            Click="IncrementMain_Click"
                            Margin="{StaticResource Mt2}"/>
                    <TextBlock Text="Click Increment here or in any SubWindow. All windows update simultaneously."
                               FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap" Margin="{StaticResource Mt2}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Open SubWindow" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb4}">
                        <Button Content="ShowDialog (Modal)" Click="OpenModal_Click" Margin="{StaticResource Mr2}"/>
                        <Button Content="Show (Non-Modal)" Click="OpenNonModal_Click"/>
                    </StackPanel>
                    <TextBlock Text="Window Log:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb1}"/>
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedSm}" Padding="{StaticResource P2}">
                        <TextBlock x:Name="LogText"
                                   FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
