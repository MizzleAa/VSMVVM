<UserControl x:Class="VSMVVM.WPF.Sample.Views.LoggingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Logging"
                       FontSize="{StaticResource Text2xl}"
                       FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="{StaticResource Mb2}"/>
            <TextBlock Text="ILoggerService demo — Send log messages at different severity levels and view them in real-time."
                       FontSize="{StaticResource TextSm}"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="{StaticResource Mb6}"
                       TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{StaticResource GridW3}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Send Panel (Left) -->
                <Border Grid.Column="0" Background="{DynamicResource BgSecondary}"
                        CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="Send Log Message"
                                   FontSize="{StaticResource TextBase}"
                                   FontWeight="{StaticResource FontSemibold}"
                                   Foreground="{DynamicResource AccentPrimary}"
                                   Margin="{StaticResource Mb3}"/>

                        <!-- Level Selector -->
                        <TextBlock Text="Level"
                                   FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="{StaticResource Mb1}"/>
                        <ComboBox ItemsSource="{Binding LogLevels}"
                                  SelectedItem="{Binding SelectedLevel, Mode=TwoWay}"
                                  Margin="{StaticResource Mb3}"/>

                        <!-- Message input -->
                        <TextBlock Text="Message"
                                   FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="{StaticResource Mb1}"/>
                        <TextBox Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="{StaticResource Mb3}"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb4}">
                            <Button Content="Send" Command="{Binding SendLogCommand}"
                                    Margin="{StaticResource Mr2}"/>
                            <Button Content="Batch (All Levels)" Command="{Binding SendBatchLogsCommand}"
                                    Style="{DynamicResource BtnOutline}"
                                    Margin="{StaticResource Mr2}"/>
                            <Button Content="Clear" Command="{Binding ClearLogsCommand}"
                                    Style="{DynamicResource BtnOutline}"/>
                        </StackPanel>

                        <!-- Log Count Badge -->
                        <Border Background="{DynamicResource BgTertiary}"
                                CornerRadius="{StaticResource RoundedSm}"
                                Padding="{StaticResource Px2Py1}" HorizontalAlignment="Left">
                            <TextBlock FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}">
                                <Run Text="Total: "/>
                                <Run Text="{Binding LogCount, Mode=OneWay}" FontWeight="{StaticResource FontSemibold}"
                                     Foreground="{DynamicResource AccentPrimary}"/>
                                <Run Text=" entries"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Log Output Panel (Right) -->
                <Border Grid.Column="2" Background="{DynamicResource BgSecondary}"
						MaxHeight="{StaticResource H96}"
                        CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Log Entries"
                                   FontSize="{StaticResource TextBase}"
                                   FontWeight="{StaticResource FontSemibold}"
                                   Foreground="{DynamicResource AccentPrimary}"
                                   Margin="{StaticResource Mb3}"/>

                        <!-- Log ListView -->
                        <ListView ItemsSource="{Binding LogEntries}"
                                  BorderThickness="{StaticResource Border0}"
                                  Background="Transparent">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="90"
                                                    DisplayMemberBinding="{Binding Timestamp}"/>
                                    <GridViewColumn Header="Level" Width="65"
                                                    DisplayMemberBinding="{Binding Level}"/>
                                    <GridViewColumn Header="Message" Width="250"
                                                    DisplayMemberBinding="{Binding Message}"/>
                                    <GridViewColumn Header="Exception" Width="180"
                                                    DisplayMemberBinding="{Binding Exception}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Raw Log Output -->
            <Border Background="{DynamicResource BgSecondary}"
                    CornerRadius="{StaticResource RoundedMd}" Padding="{StaticResource P4}"
                    Margin="{StaticResource Mt4}">
                <StackPanel>
                    <TextBlock Text="Raw Log Output"
                               FontSize="{StaticResource TextSm}"
                               FontWeight="{StaticResource FontSemibold}"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="{StaticResource Mb2}"/>
                    <TextBox Text="{Binding LogOutput, Mode=OneWay}" IsReadOnly="True"
                             Height="{StaticResource H40}" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="{StaticResource TextXs}"
                             Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
