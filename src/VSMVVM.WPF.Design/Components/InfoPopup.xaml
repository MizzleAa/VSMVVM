<UserControl x:Class="VSMVVM.WPF.Design.Components.InfoPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Index.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ToggleButton x:Name="InfoToggle"
                      Content="?"
                      Width="{StaticResource W5}"
                      Height="{StaticResource H5}"
                      FontSize="{StaticResource TextXs}"
                      Padding="{StaticResource P0}"
                      VerticalAlignment="Center"
                      Focusable="False"/>

        <Popup x:Name="InfoPopupElement"
               IsOpen="{Binding IsChecked, ElementName=InfoToggle}"
               StaysOpen="False"
               PlacementTarget="{Binding ElementName=InfoToggle}"
               Placement="Bottom"
               VerticalOffset="{StaticResource W1}"
               AllowsTransparency="True">
            <Border Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="{StaticResource Border}"
                    CornerRadius="{StaticResource RoundedMd}"
                    MaxWidth="{StaticResource W96}"
                    Margin="{StaticResource M2}"
                    Padding="{StaticResource P4}"
                    Effect="{StaticResource ShadowMd}">
                <StackPanel>
                    <!-- 타이틀 (비어있으면 자동 숨김) -->
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontWeight="{StaticResource FontBold}"
                               FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="{StaticResource Mb2}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- 본문 -->
                    <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource TextSm}"
                               Foreground="{DynamicResource TextSecondary}"
                               LineHeight="20"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
