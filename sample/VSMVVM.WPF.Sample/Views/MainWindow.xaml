<Window x:Class="VSMVVM.WPF.Sample.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VSMVVM.WPF.Controls;assembly=VSMVVM.WPF"
        xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
        xmlns:media="clr-namespace:VSMVVM.WPF.Media;assembly=VSMVVM.WPF"
        xmlns:ctrl="clr-namespace:VSMVVM.WPF.Design.Core;assembly=VSMVVM.WPF.Design"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        me:ViewModelLocator.AutoWireViewModel="True"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="{Binding Title}" Height="720" Width="1100"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen">

    <!-- AppBar Custom Button (최소화 왼쪽에 표시) -->
    <ctrl:WindowChrome.CustomButtons>
        <Button Command="{Binding ToggleInfoCommand}"
                Style="{StaticResource BtnIcon}"
                Width="{StaticResource W9}"
                Height="{StaticResource H9}"
                ToolTip="App Info"
                Focusable="False"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Image Source="{media:SvgImage Source=/VSMVVM.WPF.Sample;component/Assets/info_24.svg, Fill={StaticResource AccentPrimary}}"
                   Width="{StaticResource W4}"
                   Height="{StaticResource H4}"/>
        </Button>
    </ctrl:WindowChrome.CustomButtons>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{DynamicResource GridW60}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="{StaticResource BorderR}">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="VSMVVM"
                                   FontSize="{StaticResource TextLg}"
                                   FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource AccentPrimary}"/>
                        <TextBlock Text="WPF Sample v1.0"
                                   FontSize="{StaticResource TextXs}"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="{StaticResource Mt1}"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top"
                        Height="{StaticResource H0_5}"
                        Background="{DynamicResource BorderDefault}"
                        Margin="{StaticResource Mx2}"/>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="{StaticResource M2}">
                        <Button Content="Home"
                                Command="{Binding NavigateHomeCommand}"
                                HorizontalContentAlignment="Left"/>
                        <Button Content="Controls"
                                Command="{Binding NavigateControlsCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Components"
                                Command="{Binding NavigateComponentsCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Source Gen"
                                Command="{Binding NavigateSourceGenCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Messenger"
                                Command="{Binding NavigateMessengerCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Dialog"
                                Command="{Binding NavigateDialogCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Navigation"
                                Command="{Binding NavigateNavigationCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Validation"
                                Command="{Binding NavigateValidationCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Services"
                                Command="{Binding NavigateServicesCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="DI Lifetime"
                                Command="{Binding NavigateLifetimeCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Default Design"
                                Command="{Binding NavigateDefaultDesignCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Localization"
                                Command="{Binding NavigateLocalizationCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Multi Window"
                                Command="{Binding NavigateMultiWindowCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                        <Button Content="Canvas"
                                Command="{Binding NavigateCanvasCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="{StaticResource Mt1}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Region -->
        <Border Grid.Column="1" Padding="{StaticResource P4}">
            <controls:WPFRegion RegionName="MainRegion"/>
        </Border>
    </Grid>
</Window>
