<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========================== -->
    <!-- Sizing Scale      -->
    <!-- W = Width, H = Height      -->
    <!-- ========================== -->

    <!-- Scale 0 (0px) -->
    <sys:Double x:Key="W0">0</sys:Double>
    <sys:Double x:Key="H0">0</sys:Double>

    <!-- Scale 0.5 (2px) -->
    <sys:Double x:Key="W0_5">2</sys:Double>
    <sys:Double x:Key="H0_5">2</sys:Double>

    <!-- Scale 1 (4px) -->
    <sys:Double x:Key="W1">4</sys:Double>
    <sys:Double x:Key="H1">4</sys:Double>

    <!-- Scale 1.5 (6px) -->
    <sys:Double x:Key="W1_5">6</sys:Double>
    <sys:Double x:Key="H1_5">6</sys:Double>

    <!-- Scale 2 (8px) -->
    <sys:Double x:Key="W2">8</sys:Double>
    <sys:Double x:Key="H2">8</sys:Double>

    <!-- Scale 2.5 (10px) -->
    <sys:Double x:Key="W2_5">10</sys:Double>
    <sys:Double x:Key="H2_5">10</sys:Double>

    <!-- Scale 3 (12px) -->
    <sys:Double x:Key="W3">12</sys:Double>
    <sys:Double x:Key="H3">12</sys:Double>

    <!-- Scale 3.5 (14px) -->
    <sys:Double x:Key="W3_5">14</sys:Double>
    <sys:Double x:Key="H3_5">14</sys:Double>

    <!-- Scale 4 (16px) -->
    <sys:Double x:Key="W4">16</sys:Double>
    <sys:Double x:Key="H4">16</sys:Double>

    <!-- Scale 4.5 (18px) -->
    <sys:Double x:Key="W4_5">18</sys:Double>
    <sys:Double x:Key="H4_5">18</sys:Double>

    <!-- Scale 5 (20px) -->
    <sys:Double x:Key="W5">20</sys:Double>
    <sys:Double x:Key="H5">20</sys:Double>

    <!-- Scale 6 (24px) -->
    <sys:Double x:Key="W6">24</sys:Double>
    <sys:Double x:Key="H6">24</sys:Double>

    <!-- Scale 7 (28px) -->
    <sys:Double x:Key="W7">28</sys:Double>
    <sys:Double x:Key="H7">28</sys:Double>

    <!-- Scale 8 (32px) -->
    <sys:Double x:Key="W8">32</sys:Double>
    <sys:Double x:Key="H8">32</sys:Double>

    <!-- Scale 9 (36px) -->
    <sys:Double x:Key="W9">36</sys:Double>
    <sys:Double x:Key="H9">36</sys:Double>

    <!-- Scale 10 (40px) -->
    <sys:Double x:Key="W10">40</sys:Double>
    <sys:Double x:Key="H10">40</sys:Double>

    <!-- Scale 11 (44px) -->
    <sys:Double x:Key="W11">44</sys:Double>
    <sys:Double x:Key="H11">44</sys:Double>

    <!-- Scale 12 (48px) -->
    <sys:Double x:Key="W12">48</sys:Double>
    <sys:Double x:Key="H12">48</sys:Double>

    <!-- Scale 14 (56px) -->
    <sys:Double x:Key="W14">56</sys:Double>
    <sys:Double x:Key="H14">56</sys:Double>

    <!-- Scale 16 (64px) -->
    <sys:Double x:Key="W16">64</sys:Double>
    <sys:Double x:Key="H16">64</sys:Double>

    <!-- Scale 20 (80px) -->
    <sys:Double x:Key="W20">80</sys:Double>
    <sys:Double x:Key="H20">80</sys:Double>

    <!-- Scale 24 (96px) -->
    <sys:Double x:Key="W24">96</sys:Double>
    <sys:Double x:Key="H24">96</sys:Double>

    <!-- Scale 28 (112px) -->
    <sys:Double x:Key="W28">112</sys:Double>
    <sys:Double x:Key="H28">112</sys:Double>

    <!-- Scale 32 (128px) -->
    <sys:Double x:Key="W32">128</sys:Double>
    <sys:Double x:Key="H32">128</sys:Double>

    <!-- Scale 36 (144px) -->
    <sys:Double x:Key="W36">144</sys:Double>
    <sys:Double x:Key="H36">144</sys:Double>

    <!-- Scale 40 (160px) -->
    <sys:Double x:Key="W40">160</sys:Double>
    <sys:Double x:Key="H40">160</sys:Double>

    <!-- Scale 44 (176px) -->
    <sys:Double x:Key="W44">176</sys:Double>
    <sys:Double x:Key="H44">176</sys:Double>

    <!-- Scale 48 (192px) -->
    <sys:Double x:Key="W48">192</sys:Double>
    <sys:Double x:Key="H48">192</sys:Double>

    <!-- Scale 52 (208px) -->
    <sys:Double x:Key="W52">208</sys:Double>
    <sys:Double x:Key="H52">208</sys:Double>

    <!-- Scale 56 (224px) -->
    <sys:Double x:Key="W56">224</sys:Double>
    <sys:Double x:Key="H56">224</sys:Double>

    <!-- Scale 60 (240px) -->
    <sys:Double x:Key="W60">240</sys:Double>
    <sys:Double x:Key="H60">240</sys:Double>

    <!-- Scale 64 (256px) -->
    <sys:Double x:Key="W64">256</sys:Double>
    <sys:Double x:Key="H64">256</sys:Double>

    <!-- Scale 72 (288px) -->
    <sys:Double x:Key="W72">288</sys:Double>
    <sys:Double x:Key="H72">288</sys:Double>

    <!-- Scale 80 (320px) -->
    <sys:Double x:Key="W80">320</sys:Double>
    <sys:Double x:Key="H80">320</sys:Double>

    <!-- Scale 96 (384px) -->
    <sys:Double x:Key="W96">384</sys:Double>
    <sys:Double x:Key="H96">384</sys:Double>

    <!-- ========================== -->
    <!-- Special Values             -->
    <!-- ========================== -->
    
    <!-- Common Screen Widths (Breakpoints) -->
    <sys:Double x:Key="WXs">320</sys:Double>
    <sys:Double x:Key="WSm">640</sys:Double>
    <sys:Double x:Key="WMd">768</sys:Double>
    <sys:Double x:Key="WLg">1024</sys:Double>
    <sys:Double x:Key="WXl">1280</sys:Double>
    <sys:Double x:Key="W2xl">1536</sys:Double>

    <!-- Common Screen Heights (Breakpoints) -->
    <sys:Double x:Key="HXs">480</sys:Double>
    <sys:Double x:Key="HSm">568</sys:Double>
    <sys:Double x:Key="HMd">667</sys:Double>
    <sys:Double x:Key="HLg">844</sys:Double>
    <sys:Double x:Key="HXl">926</sys:Double>
    <sys:Double x:Key="H2xl">1024</sys:Double>

    <!-- ====================================== -->
    <!-- Mobile Device Resolutions (W × H)      -->
    <!-- ====================================== -->

    <!-- iPhone SE / 5s (568 × 426) - 4:3 -->
    <sys:Double x:Key="ScreenSE_W">568</sys:Double>
    <sys:Double x:Key="ScreenSE_H">426</sys:Double>

    <!-- iPhone 8 / 7 / 6 (667 × 500) - 4:3 -->
    <sys:Double x:Key="Screen8_W">667</sys:Double>
    <sys:Double x:Key="Screen8_H">500</sys:Double>

    <!-- iPhone X / 11 / 12 / 13 / 14 (844 × 633) - 4:3 -->
    <sys:Double x:Key="ScreenX_W">844</sys:Double>
    <sys:Double x:Key="ScreenX_H">633</sys:Double>

    <!-- iPhone Plus / Max (4:3) -->
    <sys:Double x:Key="ScreenMax_W">650</sys:Double>
    <sys:Double x:Key="ScreenMax_H">448</sys:Double>

    <!-- iPad Mini (4:3) -->
    <sys:Double x:Key="ScreenMini_W">850</sys:Double>
    <sys:Double x:Key="ScreenMini_H">638</sys:Double>

    <!-- iPad Pro (4:3) -->
    <sys:Double x:Key="ScreenPro_W">1100</sys:Double>
    <sys:Double x:Key="ScreenPro_H">825</sys:Double>

    <!-- Ultra Wide (4:3) -->
    <sys:Double x:Key="ScreenUltra_W">1300</sys:Double>
    <sys:Double x:Key="ScreenUltra_H">900</sys:Double>

	<!-- Full HD (4:3) -->
	<sys:Double x:Key="ScreenHD_W">1280</sys:Double>
	<sys:Double x:Key="ScreenHD_H">720</sys:Double>
	
	<!-- Full HD (4:3) -->
    <sys:Double x:Key="ScreenFHD_W">1600</sys:Double>
    <sys:Double x:Key="ScreenFHD_H">912</sys:Double>

    <!-- Min/Max Content Widths -->
    <sys:Double x:Key="WProse">650</sys:Double><!-- Note: WPF doesn't support ch unit, use approximate 650px -->
    <sys:Double x:Key="WProseApprox">650</sys:Double>

    <!-- ========================== -->
    <!-- Fractional Widths (%)      -->
    <!-- Note: Use with Grid ColumnDefinitions -->
    <!-- ========================== -->
    <!-- 
    Usage example:
    <ColumnDefinition Width="*"/>  = Full
    <ColumnDefinition Width="0.5*"/> = 1/2
    <ColumnDefinition Width="0.333*"/> = 1/3
    -->

    <!-- ========================== -->
    <!-- GridLength Values           -->
    <!-- For RowDefinition.Height / ColumnDefinition.Width -->
    <!-- ========================== -->
    <GridLength x:Key="GridH1">4</GridLength>
    <GridLength x:Key="GridW3">12</GridLength>
    <GridLength x:Key="GridH8">32</GridLength>
    <GridLength x:Key="GridH9">36</GridLength>
    <GridLength x:Key="GridW24">96</GridLength>
    <GridLength x:Key="GridW75">300</GridLength>
    <GridLength x:Key="GridW9">36</GridLength>
    <GridLength x:Key="GridW12">48</GridLength>
    <GridLength x:Key="GridH7_5">30</GridLength>
    <GridLength x:Key="GridW7_5">30</GridLength>
    <GridLength x:Key="GridH5">20</GridLength>
    <GridLength x:Key="GridH50">200</GridLength>
    <GridLength x:Key="GridH75">300</GridLength>
    <GridLength x:Key="GridW30">120</GridLength>
    <GridLength x:Key="GridW56">224</GridLength>
    <GridLength x:Key="GridW60">240</GridLength>

    <!-- ========================== -->
    <!-- DataGridLength Values      -->
    <!-- For DataGridColumn.Width   -->
    <!-- ========================== -->
    <DataGridLength x:Key="DgW8">32</DataGridLength>

    <!-- Extended Double values for animation targets -->
    <sys:Double x:Key="H7_5">30</sys:Double>
    <sys:Double x:Key="W7_5">30</sys:Double>
    <sys:Double x:Key="H50">200</sys:Double>
    <sys:Double x:Key="W25">100</sys:Double>
    <sys:Double x:Key="H25">100</sys:Double>
    <sys:Double x:Key="W100">400</sys:Double>
    <sys:Double x:Key="H75">300</sys:Double>

</ResourceDictionary>

