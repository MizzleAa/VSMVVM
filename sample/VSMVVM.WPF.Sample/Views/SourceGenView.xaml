<UserControl x:Class="VSMVVM.WPF.Sample.Views.SourceGenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Source Generator"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="[Property], [PropertyChangedFor], [RelayCommand], [AsyncRelayCommand] demos."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <!-- [Property] + [PropertyChangedFor] -->
            <TextBlock Text="[Property] + [PropertyChangedFor]" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Margin="{StaticResource Mb6}"
                    Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Name:" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Mb3}"/>
                    <TextBlock Text="Greeting (auto-updated via PropertyChangedFor):" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedSm}" Padding="{StaticResource P2}">
                        <TextBlock Text="{Binding Greeting}" FontSize="{StaticResource TextBase}" Foreground="{DynamicResource AccentPrimary}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- [RelayCommand] + [CanExecute] -->
            <TextBlock Text="[RelayCommand] + [CanExecute]" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Margin="{StaticResource Mb6}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Counter:" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb1}"/>
                    <TextBlock Text="{Binding Counter}" FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                               Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb3}"/>
                    <TextBlock Text="Decrement disabled when Counter = 0, Reset disabled when Counter = 0"
                               FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb2}"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Increment" Command="{Binding IncrementCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="Decrement (CanExecute)" Command="{Binding DecrementCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="Reset (CanExecute)" Command="{Binding ResetCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- [AsyncRelayCommand] + CanExecute -->
            <TextBlock Text="[AsyncRelayCommand] + [CanExecute]" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Margin="{StaticResource Mb6}"
                    Width="{StaticResource W96}" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Button disabled while running (CanExecute = !IsBusy)"
                               FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb2}"/>
                    <Button Content="Run Async Task" Command="{Binding LoadDataCommand}" Margin="{StaticResource Mb3}"/>
                    <ProgressBar Value="{Binding Progress}" Height="{StaticResource H2}" Margin="{StaticResource Mb2}"/>
                    <TextBlock Text="{Binding AsyncStatus}" FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
