<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Spacing.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Effects.xaml"/>
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Tokens/Typography.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Button Base Template -->
    <ControlTemplate x:Key="DefaultBtnTemplate" TargetType="Button">
        <Border x:Name="border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource RoundedMd}"
                Padding="{TemplateBinding Padding}"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </ControlTemplate>

    <!-- Default Button Style (자동 적용) -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextInverse}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryActive}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ToggleButton Base Template -->
    <ControlTemplate x:Key="DefaultToggleBtnTemplate" TargetType="ToggleButton">
        <Border x:Name="border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource RoundedMd}"
                Padding="{TemplateBinding Padding}"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </ControlTemplate>

    <!-- Default ToggleButton Style -->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultToggleBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderHover}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryMuted}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Default RepeatButton Style -->
    <Style TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RoundedMd}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource BgSecondary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Named Variants -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnOutline" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentPrimaryMuted}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnDanger" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Error}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextInverse}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ErrorHover}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnSuccess" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Success}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextInverse}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Px3Py2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontMedium}"/>
        <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SuccessHover}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnIcon" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource DefaultBtnTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="{StaticResource Opacity50}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
