<UserControl x:Class="VSMVVM.WPF.Sample.Views.MultiWindowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             me:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Multi Window"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="Cross-window state synchronization via SharedCounterService (Singleton) + IMessenger."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <!-- Shared Counter in Main -->
            <TextBlock Text="Shared Counter (Main)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <TextBlock Text="{Binding SharedCount}" FontSize="{StaticResource Text2xl}"
                               FontWeight="{StaticResource FontBold}" Foreground="{DynamicResource AccentPrimary}" FontFamily="Consolas"/>
                    <Button Content="Increment from Main" Command="{Binding IncrementCommand}" Margin="{StaticResource Mt2}"/>
                    <TextBlock Text="Click Increment here or in any SubWindow. All windows update simultaneously."
                               FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="{StaticResource Mt2}"/>
                </StackPanel>
            </Border>

            <!-- Open Windows -->
            <TextBlock Text="Open SubWindow" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P4}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource Mb4}">
                        <Button Content="ShowDialog (Modal)" Command="{Binding OpenDialogCommand}" Margin="{StaticResource Mr2}"/>
                        <Button Content="Show (Non-Modal)" Command="{Binding OpenNonModalCommand}"/>
                    </StackPanel>
                    <TextBlock Text="Window Log:" FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}" Margin="{StaticResource Mb1}"/>
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="{StaticResource RoundedSm}" Padding="{StaticResource P2}">
                        <TextBlock Text="{Binding WindowLog}" FontSize="{StaticResource TextSm}"
                                   Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
