<Window x:Class="VSMVVM.WPF.Sample.Views.ImageViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
        me:ViewModelLocator.AutoWireViewModel="True"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="Image View" Width="640" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}">

    <DockPanel LastChildFill="True">
        <!-- 헤더 -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgTertiary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{DynamicResource Px3Py2}">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14"
                           Foreground="{DynamicResource TextPrimary}">
                    <Run Text="ImageView:"/>
                    <Run Text="{Binding ViewName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11"
                           Margin="{DynamicResource Mt0_5}"/>
            </StackPanel>
        </Border>

        <!-- 하단: 슬라이더 + Prev/Next + 인덱스 + Close -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,1,0,0"
                Padding="{DynamicResource Px3Py2}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Command="{Binding CloseCommand}"
                        Margin="{DynamicResource Ml2}"/>

                <Button DockPanel.Dock="Left"
                        Content="⏮"
                        Command="{Binding FirstCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="First"/>
                <Button DockPanel.Dock="Left"
                        Content="◀"
                        Command="{Binding PrevCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="Previous"/>
                <Button DockPanel.Dock="Left"
                        Content="▶"
                        Command="{Binding NextCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="Next"/>
                <Button DockPanel.Dock="Left"
                        Content="⏭"
                        Command="{Binding LastCommand}"
                        Margin="{DynamicResource Mr2}"
                        ToolTip="Last"/>

                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding IndexLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontFamily="Cascadia Mono, Consolas"
                           VerticalAlignment="Center"
                           MinWidth="60"
                           Margin="{DynamicResource Mr2}"/>

                <Slider Minimum="0"
                        Maximum="{Binding MaxIndex}"
                        Value="{Binding CurrentIndex, Mode=TwoWay}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- 본문: Image -->
        <Border Background="{DynamicResource BgPrimary}" Padding="{DynamicResource P2}">
            <Image Source="{Binding ImageSource}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
    </DockPanel>
</Window>
