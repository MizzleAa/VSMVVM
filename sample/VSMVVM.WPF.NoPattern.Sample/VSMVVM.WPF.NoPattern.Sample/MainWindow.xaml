<Window x:Class="VSMVVM.WPF.NoPattern.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VSMVVM.WPF.NoPattern.Sample"
        mc:Ignorable="d"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="VSMVVM WPF — No Pattern Sample"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="{StaticResource Mt1}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{DynamicResource GridW60}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="{StaticResource BorderR}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="{StaticResource P4}">
                    <StackPanel>
                        <TextBlock Text="VSMVVM"
                                   FontSize="{StaticResource TextLg}"
                                   FontWeight="{StaticResource FontBold}"
                                   Foreground="{DynamicResource AccentPrimary}"/>
                        <TextBlock Text="WPF NoPattern Sample v1.0"
                                   FontSize="{StaticResource TextXs}"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="{StaticResource Mt1}"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top"
                        Height="{StaticResource H0_5}"
                        Background="{DynamicResource BorderDefault}"
                        Margin="{StaticResource Mx2}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MenuPanel" Margin="{StaticResource M2}">
                        <Button Content="Home"           Tag="Home"          Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Controls"       Tag="Controls"      Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Default Design" Tag="DefaultDesign" Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Components"     Tag="Components"    Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Validation"     Tag="Validation"    Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Dialog"         Tag="Dialog"        Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                        <Button Content="Multi Window"   Tag="MultiWindow"   Click="NavButton_Click" Style="{StaticResource NavButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="{StaticResource P4}">
            <ContentControl x:Name="ContentArea"/>
        </Border>
    </Grid>
</Window>
