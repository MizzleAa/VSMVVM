<UserControl x:Class="VSMVVM.WPF.Scheduler.Controls.NodeGraphToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VSMVVM.WPF.Scheduler.Converters">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverterSafe x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource BgSecondary}"
            BorderBrush="{DynamicResource BorderDefault}"
            Padding="{DynamicResource Px2}">
        <StackPanel Orientation="Horizontal">

            <Button Content="Run"
                    Command="{Binding RunCommand}"
					Margin="{StaticResource Mr1}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>

            <Button Content="Stop"
                    Command="{Binding StopCommand}"
					Margin="{StaticResource Mr1}"
                    Foreground="{DynamicResource Error}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>

            <Button Content="Continue"
                    Command="{Binding ContinueCommand}"
					Margin="{StaticResource Mr1}"
                    Foreground="{DynamicResource Warning}"
                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}"/>

            <Button Content="Step Over"
					Command="{Binding StepOverCommand}"
					Margin="{StaticResource Mr1}"
                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}"/>

            <Border Width="1" Background="{DynamicResource BorderDefault}" Margin="{DynamicResource Mx2}"/>

            <Button Content="Toggle Breakpoint"
                    Command="{Binding ToggleBreakpointCommand}"
                    Margin="{DynamicResource Mr1}"
                    Foreground="{DynamicResource ErrorText}"/>

            <Border Width="1" Background="{DynamicResource BorderDefault}" Margin="{DynamicResource Mx2}"/>

            <Button Content="Layout H"
                    Command="{Binding AutoLayoutHorizontalCommand}"
                    ToolTip="Layout H"
                    Margin="{DynamicResource Mr1}"/>

            <Button Content="Layout V"
                    Command="{Binding AutoLayoutVerticalCommand}"
                    ToolTip="Layout V"/>

        </StackPanel>
    </Border>
</UserControl>
