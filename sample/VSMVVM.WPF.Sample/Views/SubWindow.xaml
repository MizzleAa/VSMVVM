<Window x:Class="VSMVVM.WPF.Sample.Views.SubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
        me:ViewModelLocator.AutoWireViewModel="True"
        Style="{StaticResource VSMVVMWindowStyle}"
        Title="Sub Window" Width="400" Height="300"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="{StaticResource P4}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Sub Window"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding WindowId}"
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="{StaticResource Mt2}"/>
            <TextBlock Text="{Binding CreatedAt}"
                       FontSize="{StaticResource TextXs}" Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" Margin="{StaticResource Mt1}"/>

            <!-- Shared Counter -->
            <Border Background="{DynamicResource BgSecondary}" CornerRadius="{StaticResource RoundedMd}"
                    Padding="{StaticResource P3}" Margin="{StaticResource Mt4}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Shared Counter" FontSize="{StaticResource TextXs}"
                               Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding SharedCount}" FontSize="{StaticResource Text2xl}"
                               FontWeight="{StaticResource FontBold}" Foreground="{DynamicResource AccentPrimary}"
                               HorizontalAlignment="Center" FontFamily="Consolas"/>
                    <Button Content="Increment from Sub" Command="{Binding IncrementCommand}"
                            HorizontalAlignment="Center" Margin="{StaticResource Mt2}"/>
                </StackPanel>
            </Border>

            <Button Content="Close" Command="{Binding CloseCommand}"
                    HorizontalAlignment="Center" Margin="{StaticResource Mt4}"/>
        </StackPanel>
    </Grid>
</Window>
