<UserControl x:Class="VSMVVM.WPF.Sample.Views.SchedulerDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:me="clr-namespace:VSMVVM.WPF.MarkupExtensions;assembly=VSMVVM.WPF"
             xmlns:views="clr-namespace:VSMVVM.WPF.Sample.Views"
             xmlns:vm="clr-namespace:VSMVVM.WPF.Sample.ViewModels"
             me:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BgPrimary}">

    <!--
        멀티 탭 컨테이너. DataContext = SchedulerDemoViewModel (Workspaces + ActiveWorkspace + Run/Stop All).
        상단: 컨테이너 액션 바 (+ New Tab, Run All, Stop All)
        중앙: TabControl(Workspaces) → 각 TabItem 의 Content = WorkspaceView
    -->
    <DockPanel LastChildFill="True">

        <!-- 컨테이너 액션 바 -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{DynamicResource P2}">
            <StackPanel Orientation="Horizontal">
                <Button Content="New Tab"
                        Command="{Binding NewWorkspaceCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="새 워크스페이스 생성 (Ctrl+T)"/>

                <Border Width="1"
                        Background="{DynamicResource BorderDefault}"
                        Margin="{DynamicResource Mx2}"/>

                <Button Content="Run All"
                        Command="{Binding RunAllWorkspacesCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="모든 워크스페이스 동시 실행 (Ctrl+Shift+F5)"/>
                <Button Content="Stop All"
                        Command="{Binding StopAllWorkspacesCommand}"
                        Foreground="{DynamicResource Error}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="모든 워크스페이스 실행 중지"/>

                <Border Width="1"
                        Background="{DynamicResource BorderDefault}"
                        Margin="{DynamicResource Mx2}"/>

                <!-- Phase M — 사용자 코드 전역. NodeMetadataRegistry 가 프로세스 전역이라 모든 탭이 공유. -->
                <Button Content="Edit Code…"
                        Command="{Binding OpenUserCodeEditorCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="모든 탭이 공유하는 사용자 코드 에디터"/>
                <Button Content="Save Code…"
                        Command="{Binding SaveCodeJsonCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="모든 사용자 코드 조각을 JSON 파일로 저장 (디폴트: %APPDATA%/VSMVVM.WPF.Sample/userCode.json)"/>
                <Button Content="Load Code…"
                        Command="{Binding LoadCodeJsonCommand}"
                        Margin="{DynamicResource Mr1}"
                        ToolTip="사용자 코드 JSON 로드 + 자동 컴파일"/>
            </StackPanel>
        </Border>

        <!-- 컨테이너 상태 메시지 (사용자 코드 컴파일/저장/로드 결과). 빈 문자열이면 자동 hide. -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgPrimary}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{DynamicResource Px3Py1}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ContainerStatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ContainerStatusMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ContainerStatusMessage}"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="11"/>
        </Border>

        <!--
            워크스페이스 탭. Workspaces 가 비어있으면 빈 화면 (사용자 결정 — 마지막 탭 닫기 허용).
            각 TabItem.Header 는 DisplayName + "×" 버튼.
            TabItem.Content 는 WorkspaceView, DataContext = 그 워크스페이스.
        -->
        <TabControl ItemsSource="{Binding Workspaces}"
                    SelectedItem="{Binding ActiveWorkspace}"
                    Background="{DynamicResource BgPrimary}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SampleWorkspaceViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   Margin="{DynamicResource Mr2}"/>
                        <Button Content="×"
                                FontSize="11"
                                Padding="6,0"
                                MinHeight="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextMuted}"
                                ToolTip="이 탭 닫기 (Ctrl+W)"
                                Command="{Binding DataContext.CloseWorkspaceCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SampleWorkspaceViewModel}">
                    <views:WorkspaceView DataContext="{Binding}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</UserControl>
