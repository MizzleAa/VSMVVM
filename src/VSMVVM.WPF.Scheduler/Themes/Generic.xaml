<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:VSMVVM.WPF.Scheduler.Controls">

    <ResourceDictionary.MergedDictionaries>
        <!-- VSMVVM.WPF.Design 머지 — Spacing/Sizing/Typography/Effects 토큰 + Palette + ThemeDark + 컴포넌트 스타일 일괄 적용. -->
        <ResourceDictionary Source="/VSMVVM.WPF.Design;component/Index.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Default style for NodeGraphCanvas -->
    <Style TargetType="{x:Type local:NodeGraphCanvas}">
        <Setter Property="Background" Value="{DynamicResource BgPrimary}"/>
    </Style>

</ResourceDictionary>
