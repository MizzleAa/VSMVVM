<UserControl x:Class="VSMVVM.WPF.NoPattern.Sample.Views.DefaultDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource P2}">
        <StackPanel>
            <TextBlock Text="Default Design"
                       FontSize="{StaticResource Text2xl}" FontWeight="{StaticResource FontBold}"
                       Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb4}"/>
            <TextBlock Text="VSMVVM.WPF.Design default styles. No explicit Style assignment needed."
                       FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource Mb6}"/>

            <TextBlock Text="Button (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <WrapPanel Margin="{StaticResource Mb6}">
                <Button Content="Normal" Margin="{StaticResource Mr2}"/>
                <Button Content="Hovered" Margin="{StaticResource Mr2}"/>
                <Button Content="Disabled" IsEnabled="False" Margin="{StaticResource Mr2}"/>
            </WrapPanel>

            <TextBlock Text="TextBox (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <StackPanel Margin="{StaticResource Mb6}">
                <TextBox Text="Editable" Width="{StaticResource W64}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <TextBox Text="ReadOnly" IsReadOnly="True" Width="{StaticResource W64}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <TextBox Text="Disabled" IsEnabled="False" Width="{StaticResource W64}" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Text="CheckBox (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <WrapPanel Margin="{StaticResource Mb6}">
                <CheckBox Content="Checked" IsChecked="True" Margin="{StaticResource Mr4}"/>
                <CheckBox Content="Unchecked" Margin="{StaticResource Mr4}"/>
                <CheckBox Content="Disabled" IsEnabled="False" IsChecked="True" Margin="{StaticResource Mr4}"/>
            </WrapPanel>

            <TextBlock Text="RadioButton (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <WrapPanel Margin="{StaticResource Mb6}">
                <RadioButton Content="Option A" IsChecked="True" GroupName="DD1" Margin="{StaticResource Mr4}"/>
                <RadioButton Content="Option B" GroupName="DD1" Margin="{StaticResource Mr4}"/>
                <RadioButton Content="Disabled" IsEnabled="False" GroupName="DD1" Margin="{StaticResource Mr4}"/>
            </WrapPanel>

            <TextBlock Text="ComboBox (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <ComboBox Width="{StaticResource W64}" HorizontalAlignment="Left" SelectedIndex="0" Margin="{StaticResource Mb6}">
                <ComboBoxItem Content="Option Alpha"/>
                <ComboBoxItem Content="Option Beta"/>
                <ComboBoxItem Content="Option Gamma"/>
            </ComboBox>

            <TextBlock Text="ProgressBar (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <StackPanel Margin="{StaticResource Mb6}">
                <ProgressBar Value="40" Width="{StaticResource W64}" Height="{StaticResource H2}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <ProgressBar Value="75" Width="{StaticResource W64}" Height="{StaticResource H2}" HorizontalAlignment="Left" Margin="{StaticResource Mb2}"/>
                <ProgressBar IsIndeterminate="True" Width="{StaticResource W64}" Height="{StaticResource H2}" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Text="Slider (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Slider Width="{StaticResource W64}" HorizontalAlignment="Left" Minimum="0" Maximum="100" Value="50" Margin="{StaticResource Mb6}"/>

            <TextBlock Text="TabControl (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <TabControl Width="{StaticResource W96}" Height="{StaticResource H32}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <TabItem Header="First">
                    <TextBlock Text="First tab content" Margin="{StaticResource P4}" Foreground="{DynamicResource TextPrimary}"/>
                </TabItem>
                <TabItem Header="Second">
                    <TextBlock Text="Second tab content" Margin="{StaticResource P4}" Foreground="{DynamicResource TextPrimary}"/>
                </TabItem>
            </TabControl>

            <TextBlock Text="Expander (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Expander Header="Expand me" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <TextBlock Text="Expandable content with default Design styling." Foreground="{DynamicResource TextSecondary}" Margin="{StaticResource P3}"/>
            </Expander>

            <TextBlock Text="ToolTip (default)" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Button Content="Hover for default ToolTip" ToolTip="Default styled ToolTip" Margin="{StaticResource Mb6}"/>

            <TextBlock Text="SectionPanel" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Style="{StaticResource SectionPanel}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <TextBlock Text="Section Title" FontSize="{StaticResource TextLg}" FontWeight="{StaticResource FontBold}"
                               Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb2}"/>
                    <TextBlock Text="A card-like container with rounded corners, border, and drop shadow."
                               FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="GlassPanel" FontSize="{StaticResource TextBase}" FontWeight="{StaticResource FontSemibold}"
                       Foreground="{DynamicResource AccentPrimary}" Margin="{StaticResource Mb2}"/>
            <Border Style="{StaticResource GlassPanel}" Width="{StaticResource W96}" HorizontalAlignment="Left" Margin="{StaticResource Mb6}">
                <StackPanel>
                    <TextBlock Text="Glass Card" FontSize="{StaticResource TextLg}" FontWeight="{StaticResource FontSemibold}"
                               Foreground="{DynamicResource TextPrimary}" Margin="{StaticResource Mb1}"/>
                    <TextBlock Text="Semi-transparent background for glassmorphism effect."
                               FontSize="{StaticResource TextSm}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
